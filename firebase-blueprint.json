{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and course access information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "purchasedCourses": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "PaymentProof": {
      "title": "Payment Proof",
      "description": "User submitted payment verification details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "utrId": { "type": "string" },
        "courseId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "utrId", "courseId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "/paymentProofs/{proofId}": {
      "schema": "PaymentProof",
      "description": "Stores payment verification requests."
    }
  }
}
